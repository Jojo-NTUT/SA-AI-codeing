{
  "useCase": "CreateTask",
  "behavior": "Create a new task inside a ProductBacklogItem aggregate.",
  "input": [
    { "name": "productId", "type": "String", "note": "Product id." },
    { "name": "pbiId", "type": "String", "note": "ProductBacklogItem id." },
    { "name": "taskId", "type": "String", "note": "Task id." },
    { "name": "name", "type": "String", "note": "Task name." },
    { "name": "estimatedHours", "type": "String", "note": "Nullable decimal hours, such as 0.5, 1.5, or 8." },
    { "name": "creatorId", "type": "String", "note": "User id that creates the task." }
  ],
  "aggregate": "ProductBacklogItem",
  "aggregateId": "PbiId",
  "method": "ProductBacklogItem.createTask(TaskId taskId, String name, EstimatedHours estimatedHours, String creatorId)",
  "domainEvent": "ProductBacklogItemEvents.TaskCreated",
  "repository": "ProductBacklogItemRepository",
  "output": "CqrsOutput with taskId",
  "businessRules": [
    "A task cannot be created with duplicate taskId in the same PBI.",
    "A newly-created task has TODO state.",
    "If estimatedHours is provided, remainingHours starts with the same value.",
    "If PBI is DONE, creating a new task regresses PBI to IN_PROGRESS."
  ],
  "domainModelNotes": [
    "requireNotNull(\"task ID is not null\", () -> taskId)",
    "requireNotNull(\"name is not null\", () -> name)",
    "requireNotNull(\"creator ID is not null\", () -> creatorId)",
    "If state == DONE, emit PbiWorkRegressed after TaskCreated.",
    "Aggregate accessors must expose Task as ReadOnlyTask runtime instances."
  ],
  "aggregates": [
    {
      "name": "ProductBacklogItem",
      "attributes": [
        { "name": "productId", "type": "ProductId", "constraint": "non-null" },
        { "name": "pbiId", "type": "PbiId", "constraint": "non-null" },
        { "name": "state", "type": "PbiState", "constraint": "non-null" },
        { "name": "tasks", "type": "Map<TaskId, Task>", "constraint": "non-null", "semantics": "collection_reference_immutable" }
      ]
    }
  ],
  "entities": [
    {
      "name": "Task",
      "mutable": true,
      "exposed": true,
      "attributes": [
        { "name": "id", "type": "TaskId", "constraint": "non-null" },
        { "name": "pbiId", "type": "PbiId", "constraint": "non-null" },
        { "name": "name", "type": "String", "constraint": "non-null", "mutable": true },
        { "name": "state", "type": "TaskState", "constraint": "non-null", "mutable": true },
        { "name": "assigneeIds", "type": "Set<String>", "constraint": "non-null", "mutable": true },
        { "name": "estimatedHours", "type": "EstimatedHours", "constraint": "nullable", "mutable": true },
        { "name": "remainingHours", "type": "RemainingHours", "constraint": "nullable", "mutable": true },
        { "name": "blockedBy", "type": "List<String>", "constraint": "non-null", "mutable": true },
        { "name": "note", "type": "String", "constraint": "nullable", "mutable": true },
        { "name": "extension", "type": "String", "constraint": "nullable", "mutable": true }
      ]
    }
  ],
  "domainEvents": [
    {
      "name": "ProductBacklogItemEvents.TaskCreated",
      "description": "Task was created in a ProductBacklogItem.",
      "attributes": [
        { "name": "productId", "type": "ProductId", "constraint": "non-null" },
        { "name": "pbiId", "type": "PbiId", "constraint": "non-null" },
        { "name": "taskId", "type": "TaskId", "constraint": "non-null" },
        { "name": "name", "type": "String", "constraint": "non-null" },
        { "name": "estimatedHours", "type": "EstimatedHours", "constraint": "nullable" },
        { "name": "remainingHours", "type": "RemainingHours", "constraint": "nullable" },
        { "name": "note", "type": "String", "constraint": "nullable" },
        { "name": "extension", "type": "String", "constraint": "nullable" },
        { "name": "creatorId", "type": "String", "constraint": "non-null" }
      ]
    },
    {
      "name": "ProductBacklogItemEvents.PbiWorkRegressed",
      "description": "PBI moved from DONE back to IN_PROGRESS because a new non-done task was created.",
      "attributes": [
        { "name": "productId", "type": "ProductId", "constraint": "non-null" },
        { "name": "sprintId", "type": "SprintId", "constraint": "nullable" },
        { "name": "pbiId", "type": "PbiId", "constraint": "non-null" },
        { "name": "previousState", "type": "PbiState", "constraint": "non-null" },
        { "name": "newState", "type": "PbiState", "constraint": "non-null" },
        { "name": "regressedBy", "type": "String", "constraint": "non-null" },
        { "name": "reason", "type": "String", "constraint": "non-null" },
        { "name": "extension", "type": "Map<String, String>", "constraint": "nullable" }
      ],
      "triggerCondition": "PBI.state == PbiState.DONE"
    }
  ],
  "testScenarios": [
    {
      "name": "should_create_task_successfully",
      "given": "A ProductBacklogItem exists.",
      "when": "CreateTaskUseCase is executed.",
      "then": [
        "TaskCreated event is generated.",
        "Aggregate getTask returns a ReadOnlyTask runtime instance.",
        "Attempting to mutate the returned task throws UnsupportedOperationException."
      ]
    }
  ]
}
