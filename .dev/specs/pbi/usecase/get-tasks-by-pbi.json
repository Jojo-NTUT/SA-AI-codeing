{
  "query": "GetTasksByProductBacklogItem",
  "behavior": "Get all tasks for a ProductBacklogItem as List<TaskDto>.",
  "input": [
    { "name": "pbiId", "type": "String", "note": "ProductBacklogItem id." }
  ],
  "method": "tasksDtoProjection.query",
  "output": "GetTasksByProductBacklogItemOutput",
  "domainModelNotes": [
    "Projection obtains tasks from the aggregate accessor.",
    "Aggregate accessor must return ReadOnlyTask runtime instances while mapper signatures stay Task-based."
  ],
  "dependencies": [
    { "name": "tasksDtoProjection", "type": "TasksDtoProjection", "note": "Queries tasks by PBI id." }
  ],
  "projections": [
    {
      "name": "TasksDtoProjection extends Projection<TasksDtoProjectionInput, List<TaskDto>>",
      "description": "Find ProductBacklogItem by pbiId and map its exposed read-only tasks to TaskDto.",
      "input": [
        { "name": "pbiId", "type": "String" }
      ]
    }
  ],
  "dataTransferObjects": [
    {
      "name": "TaskDto",
      "description": "Task DTO.",
      "fields": [
        { "name": "id", "type": "String" },
        { "name": "pbiId", "type": "String" },
        { "name": "name", "type": "String" },
        { "name": "state", "type": "String" },
        { "name": "assigneeIds", "type": "Set<String>" },
        { "name": "estimatedHours", "type": "EstimatedHoursDto" },
        { "name": "remainingHours", "type": "RemainingHoursDto" },
        { "name": "blockedBy", "type": "List<String>" },
        { "name": "note", "type": "String" },
        { "name": "extension", "type": "String" }
      ]
    },
    {
      "name": "EstimatedHoursDto",
      "description": "Estimated hours DTO.",
      "fields": [
        { "name": "value", "type": "String" }
      ]
    },
    {
      "name": "RemainingHoursDto",
      "description": "Remaining hours DTO.",
      "fields": [
        { "name": "value", "type": "String" }
      ]
    }
  ],
  "mappers": [
    {
      "name": "TaskMapper",
      "description": "Map Task entity to TaskDto.",
      "location": "pbi.usecase.port",
      "critical": true,
      "methods": [
        "toDto(Task task) -> TaskDto",
        "toDtoList(List<Task> tasks) -> List<TaskDto>"
      ],
      "note": "Mapper keeps Task signatures. The aggregate supplies ReadOnlyTask runtime instances."
    },
    {
      "name": "EstimatedHoursMapper",
      "description": "Map EstimatedHours value object to EstimatedHoursDto.",
      "location": "pbi.usecase.port",
      "critical": true,
      "methods": [
        "toDto(EstimatedHours hours) -> EstimatedHoursDto",
        "toDomain(EstimatedHoursDto dto) -> EstimatedHours"
      ]
    },
    {
      "name": "RemainingHoursMapper",
      "description": "Map RemainingHours value object to RemainingHoursDto.",
      "location": "pbi.usecase.port",
      "critical": true,
      "methods": [
        "toDto(RemainingHours hours) -> RemainingHoursDto",
        "toDomain(RemainingHoursDto dto) -> RemainingHours"
      ]
    }
  ],
  "testDataSetup": {
    "description": "Create one PBI and three tasks.",
    "steps": [
      {
        "order": 1,
        "useCase": "CreateProductBacklogItemUseCase",
        "input": {
          "productId": "product-123",
          "pbiId": "pbi-456",
          "name": "User authentication feature",
          "creatorId": "user-789"
        }
      },
      {
        "order": 2,
        "useCase": "CreateTaskUseCase",
        "input": {
          "productId": "product-123",
          "pbiId": "pbi-456",
          "taskId": "task-001",
          "name": "Design authentication API",
          "estimatedHours": null,
          "creatorId": "user-789"
        }
      },
      {
        "order": 3,
        "useCase": "CreateTaskUseCase",
        "input": {
          "productId": "product-123",
          "pbiId": "pbi-456",
          "taskId": "task-002",
          "name": "Implement login endpoint",
          "estimatedHours": "8",
          "creatorId": "user-789"
        }
      },
      {
        "order": 4,
        "useCase": "CreateTaskUseCase",
        "input": {
          "productId": "product-123",
          "pbiId": "pbi-456",
          "taskId": "task-003",
          "name": "Write unit tests",
          "estimatedHours": "4",
          "creatorId": "user-789"
        }
      }
    ]
  },
  "testScenarios": [
    {
      "name": "should_get_all_tasks_for_pbi_successfully",
      "given": "A PBI has three tasks.",
      "when": "GetTasksByProductBacklogItemUseCase queries the PBI.",
      "then": [
        "Output contains three TaskDto entries.",
        "Projection maps ReadOnlyTask runtime instances through TaskMapper.",
        "All tasks have TODO state."
      ]
    },
    {
      "name": "should_return_empty_list_when_pbi_has_no_tasks",
      "given": "A PBI exists without tasks.",
      "when": "GetTasksByProductBacklogItemUseCase queries the PBI.",
      "then": [
        "Output contains an empty list.",
        "ExitCode is SUCCESS."
      ]
    },
    {
      "name": "should_return_empty_list_when_pbi_not_found",
      "given": "No PBI exists for the pbiId.",
      "when": "GetTasksByProductBacklogItemUseCase queries the missing pbiId.",
      "then": [
        "Output contains an empty list.",
        "ExitCode is SUCCESS."
      ]
    }
  ]
}
